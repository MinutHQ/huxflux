{
  "expo": {
    "name": "Huxflux",
    "slug": "huxflux-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "huxflux",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.huxflux.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.huxflux.mobile"
    },
    "plugins": [
      "expo-router",
      "./plugins/withCleartextTraffic",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0a0a0a",
          "sounds": []
        }
      ]
    ]
  }
}
