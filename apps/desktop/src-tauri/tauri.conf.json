{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Huxflux",
  "identifier": "com.huxflux.desktop",
  "version": "0.0.1",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm vite --port 1420",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Huxflux",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlistAdditions": {
        "NSUserNotificationUsageDescription": "Huxflux notifies you when your AI agents complete their tasks."
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGODkwMEZGQjBDQzU0REYKUldUZlZNeXcvd0NKbnlDQ1JJc0RFWEFQM1dBZDN4VVV5cDVLMTMzdnJrU0p6dGJhNzNOOUJyNjUK",
      "endpoints": [
        "https://github.com/AlexMartosP/huxflux-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
