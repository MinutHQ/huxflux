{
  "name": "@alexmartosp/huxflux",
  "version": "0.2.11",
  "description": "Huxflux server — run Claude agents on any machine",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "bin": {
    "huxflux": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "dev:start": "node scripts/dev-daemon.mjs start",
    "dev:stop": "node scripts/dev-daemon.mjs stop",
    "dev:logs": "node scripts/dev-daemon.mjs logs",
    "dev:status": "node scripts/dev-daemon.mjs status",
    "build": "tsup && node -e \"const fs=require('fs');['dist/index.js','dist/cli.js'].forEach(f=>{try{fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/from\\\"sqlite\\\"/g,'from\\\"node:sqlite\\\"'))}catch{}})\"",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.2",
    "@octokit/rest": "^21.1.1",
    "chokidar": "^5.0.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.2",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "simple-git": "^3.27.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3"
  }
}
