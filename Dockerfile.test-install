# Huxflux install e2e test
# Simulates a fresh user on a headless Linux machine.
#
# Build:  docker build -f Dockerfile.test-install -t huxflux-test .
# Run:    docker run -it huxflux-test
#
# Inside the container you get a shell. Run:
#   bash install.sh        # full install flow
#   huxflux setup          # just the setup wizard
#   huxflux status         # check server
#   curl localhost:4321/health  # verify API

FROM node:22-slim

RUN apt-get update && apt-get install -y \
  git \
  curl \
  && rm -rf /var/lib/apt/lists/*

# Create a non-root user (realistic install scenario)
RUN useradd -m -s /bin/bash tester
USER tester
WORKDIR /home/tester

# Copy the install script
COPY --chown=tester:tester install.sh ./install.sh

# Drop into a shell — user runs install manually
CMD ["bash"]
