{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    // TEMPORARY: pre-existing implicit-any params across server routes. Re-enable
    // (remove this override) as each server domain is extracted into domains/<name>/
    // with explicit types. Tracked as part of the migration backlog.
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src", "test", "vitest.config.ts"]
}
