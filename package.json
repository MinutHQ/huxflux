{
  "name": "huxflux",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter huxflux-web dev",
    "dev:server": "pnpm --filter @alexmartosp/huxflux dev",
    "dev:start": "pnpm --filter @alexmartosp/huxflux dev:start",
    "dev:stop": "pnpm --filter @alexmartosp/huxflux dev:stop",
    "dev:logs": "pnpm --filter @alexmartosp/huxflux dev:logs",
    "dev:status": "pnpm --filter @alexmartosp/huxflux dev:status",
    "dev:desktop": "pnpm --filter huxflux-desktop dev",
    "build": "pnpm --filter huxflux-web build && pnpm --filter @alexmartosp/huxflux build",
    "build:desktop": "pnpm --filter huxflux-desktop build",
    "dev:docs": "pnpm --filter huxflux-docs dev",
    "build:docs": "pnpm --filter huxflux-docs build"
  },
  "pnpm": {
    "patchedDependencies": {
      "@radix-ui/react-compose-refs@1.1.2": "patches/@radix-ui__react-compose-refs@1.1.2.patch"
    }
  }
}
