# Path to claude CLI binary (default: /opt/homebrew/bin/claude)
# CLAUDE_BIN=/opt/homebrew/bin/claude

# Server port
PORT=3001

# GitHub personal access token (for PR creation, branch listing)
GITHUB_TOKEN=ghp_your_token_here

# Base path for git worktrees (default: ~/.hive/workspaces)
# WORKSPACES_BASE=~/.hive/workspaces

# SQLite database file path
DB_PATH=./hive.db

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173
