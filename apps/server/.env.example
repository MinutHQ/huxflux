# Path to claude CLI binary (default: /opt/homebrew/bin/claude)
# CLAUDE_BIN=/opt/homebrew/bin/claude

# Server port
PORT=4321

# Auth token — required, all requests (except /health) will be rejected without it
AUTH_TOKEN=your_secret_token_here

# GitHub personal access token (for PR creation, branch listing)
GITHUB_TOKEN=ghp_your_token_here

# Base path for git worktrees (default: ~/huxflux/workspaces)
# WORKSPACES_BASE=~/huxflux/workspaces

# Allowed CORS origins (comma-separated, default: allow all)
# CORS_ORIGINS=http://localhost:5173

# GitHub repo for feedback issue creation (owner/repo format)
FEEDBACK_REPO=AlexMartosP/huxflux-feedback
