{
  "name": "huxflux",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev:web": "pnpm --filter huxflux-web dev",
    "dev:server": "pnpm --filter @minuthq/huxflux dev",
    "dev:start": "pnpm --filter @minuthq/huxflux dev:start",
    "dev:stop": "pnpm --filter @minuthq/huxflux dev:stop",
    "dev:logs": "pnpm --filter @minuthq/huxflux dev:logs",
    "dev:status": "pnpm --filter @minuthq/huxflux dev:status",
    "dev:desktop": "pnpm --filter huxflux-desktop dev",
    "build": "pnpm --filter huxflux-web build && pnpm --filter @minuthq/huxflux build",
    "build:desktop": "pnpm --filter huxflux-desktop build",
    "dev:docs": "pnpm --filter huxflux-docs dev",
    "build:docs": "pnpm --filter huxflux-docs build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint . && node scripts/check-domains.mjs && node scripts/check-migrations.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
